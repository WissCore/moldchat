# Default: auto-detect text and normalize line endings to LF on commit
* text=auto eol=lf

# Source code: explicit text, LF
*.go         text eol=lf
*.kt         text eol=lf
*.kts        text eol=lf
*.swift      text eol=lf
*.java       text eol=lf
*.proto      text eol=lf
*.sh         text eol=lf
*.bash       text eol=lf
*.py         text eol=lf
*.rs         text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.scss       text eol=lf
*.md         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.toml       text eol=lf
*.json       text eol=lf
*.xml        text eol=lf
*.gradle     text eol=lf

# Windows-only files: CRLF
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# Binary assets
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.webp       binary
*.ico        binary
*.icns       binary
*.pdf        binary
*.zip        binary
*.tar.gz     binary
*.tgz        binary
*.7z         binary
*.dmg        binary
*.exe        binary
*.dll        binary
*.so         binary
*.dylib      binary
*.a          binary
*.aar        binary
*.apk        binary
*.aab        binary
*.ipa        binary
*.jar        binary

# Linguist overrides
*.kt         linguist-language=Kotlin
*.kts        linguist-language=Kotlin

# Generated files marked as such
*.pb.go      linguist-generated=true
*_generated.go linguist-generated=true
docs/specs/* linguist-documentation=true
